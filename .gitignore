# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Data (large files - never commit raw/interim/processed data)
data/raw/
data/interim/
data/processed/
*.h5ad
*.h5
*.parquet
*.tsv
*.csv
*.zip
*.tar.gz
*.pkl
*.pt
*.pth

# Results (regenerated each run)
results/tables/
results/figures/
results/checkpoints/
results/models/
results/logs/

# Testing / coverage artifacts
.coverage
.coverage.*
.pytest_cache/
htmlcov/
*.log

# Notebooks (serve as scratch)
notebooks/

# Environment
.env
.venv/
# environment.yml is committed (needed to reproduce from a clean clone).
# Regenerate with `conda env export --no-builds > environment.yml` if deps change.

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Credentials / secrets (DO NOT commit real credentials)
服务器配置
*.local
*.secret
*.key
*.pem
.env.*
credentials/

# OS
Thumbs.db
.DS_Store

# LaTeX build artifacts (regenerated by pdflatex; only main.pdf is committed)
submission_bundle_BiB/01_manuscript/*.aux
submission_bundle_BiB/01_manuscript/*.log
submission_bundle_BiB/01_manuscript/*.out
submission_bundle_BiB/01_manuscript/*.bbl
submission_bundle_BiB/01_manuscript/*.blg

# --- Committed exceptions: the paper snapshot must survive a clean clone ---
# (overrides the *.tsv / results / data rules above for the submission bundle)
!submission_package/
!submission_package/**
!submission_bundle_BiB/
!submission_bundle_BiB/**
!requirements.txt
!manuscript/figures/**
